# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ffa:ffa@localhost:5432/ffa"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="CHANGE_ME_32_CHARS_MIN"

# ── Resend (UK endpoint) ──────────────────────────────────────────────────────
RESEND_API_KEY="re_CHANGE_ME"
EMAIL_FROM="FFA <noreply@ffa.law>"

# ── AWS S3 eu-west-2 ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID="CHANGE_ME"
AWS_SECRET_ACCESS_KEY="CHANGE_ME"
AWS_S3_BUCKET="ffa-documents-production"
# Region is hardcoded to eu-west-2 in lib/s3.ts — do not change

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN="https://CHANGE_ME@sentry.io/CHANGE_ME"
SENTRY_ORG="CHANGE_ME"
SENTRY_PROJECT="ffa"

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
APP_VERSION="1.0.0"
NODE_ENV="development"
